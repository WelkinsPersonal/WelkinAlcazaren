<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>John Welkin Alcazaren — YouTube Editor & Creator</title>
<meta name="description" content="Freelance YouTube video editor and content strategist with 3-4 years of experience. Open for projects.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&family=DM+Mono&display=swap" rel="stylesheet">
<style>
:root {
  --bg:         #0C0C0C;
  --surface:    #161616;
  --card:       #1C1C1C;
  --border:     #2A2A2A;
  --accent:     #E8332A;
  --accent-dim: rgba(232,51,42,0.15);
  --text:       #F0F0F0;
  --text-mid:   #999999;
  --text-dim:   #555555;
  --green:      #22c55e;
  --green-dim:  rgba(34,197,94,0.15);
  --red:        #E8332A;
  --red-dim:    rgba(232,51,42,0.15);
}
* { margin:0; padding:0; box-sizing:border-box; }
html { scroll-behavior:smooth; }
body { background:var(--bg); color:var(--text); font-family:'DM Sans',sans-serif; font-size:16px; line-height:1.6; overflow-x:hidden; }
body::before { content:''; position:fixed; inset:0; background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E"); pointer-events:none; z-index:0; opacity:0.4; }

nav { position:fixed; top:0; left:0; right:0; z-index:100; display:flex; justify-content:space-between; align-items:center; padding:1.2rem 2.5rem; border-bottom:1px solid transparent; transition:border-color 0.3s, background 0.3s; }
nav.scrolled { background:rgba(12,12,12,0.92); backdrop-filter:blur(12px); border-color:var(--border); }
.nav-logo { font-family:'Syne',sans-serif; font-weight:800; font-size:1.1rem; color:var(--text); text-decoration:none; letter-spacing:-0.5px; }
.nav-logo span { color:var(--accent); }
.nav-links { display:flex; gap:2rem; list-style:none; }
.nav-links a { color:var(--text-mid); text-decoration:none; font-size:0.875rem; font-weight:500; transition:color 0.2s; }
.nav-links a:hover { color:var(--text); }
.nav-cta { background:var(--accent); color:#fff !important; padding:0.45rem 1.1rem; border-radius:6px; font-weight:500 !important; }

#hero { min-height:100vh; display:flex; align-items:center; padding:6rem 2.5rem 4rem; position:relative; }
.hero-inner { max-width:900px; margin:0 auto; width:100%; }
.hero-eyebrow { font-family:'DM Mono',monospace; font-size:0.8rem; color:var(--accent); letter-spacing:2px; text-transform:uppercase; margin-bottom:1.2rem; display:flex; align-items:center; gap:0.75rem; }
.hero-eyebrow::before { content:''; display:inline-block; width:24px; height:1px; background:var(--accent); }
.hero-name { font-family:'Syne',sans-serif; font-size:clamp(2.8rem,7vw,5.5rem); font-weight:800; line-height:1.0; letter-spacing:-2px; margin-bottom:1rem; }
.hero-name .line2 { color:var(--text-mid); }
.hero-role-wrap { font-family:'Syne',sans-serif; font-size:clamp(1.1rem,2.5vw,1.6rem); font-weight:600; color:var(--text-mid); margin-bottom:1.8rem; height:2.2rem; display:flex; align-items:center; gap:0.5rem; }
.hero-role-text { color:var(--accent); }
.cursor { display:inline-block; width:2px; height:1.2em; background:var(--accent); margin-left:2px; animation:blink 1s step-end infinite; vertical-align:middle; }
@keyframes blink { 0%,100%{opacity:1} 50%{opacity:0} }
.hero-bio { font-size:1rem; color:var(--text-mid); max-width:520px; line-height:1.8; margin-bottom:2.5rem; }
.hero-actions { display:flex; gap:1rem; flex-wrap:wrap; }
.btn-primary { background:var(--accent); color:#fff; padding:0.75rem 1.8rem; border-radius:8px; font-weight:500; text-decoration:none; font-size:0.95rem; transition:opacity 0.2s, transform 0.2s; display:inline-flex; align-items:center; gap:0.5rem; }
.btn-primary:hover { opacity:0.88; transform:translateY(-1px); }
.btn-outline { background:transparent; color:var(--text); padding:0.75rem 1.8rem; border-radius:8px; font-weight:500; text-decoration:none; font-size:0.95rem; border:1px solid var(--border); transition:border-color 0.2s, transform 0.2s; display:inline-flex; align-items:center; gap:0.5rem; }
.btn-outline:hover { border-color:var(--text-mid); transform:translateY(-1px); }
.hero-stats { display:flex; gap:2.5rem; margin-top:3.5rem; padding-top:2rem; border-top:1px solid var(--border); flex-wrap:wrap; }
.stat-num { font-family:'Syne',sans-serif; font-size:2rem; font-weight:800; line-height:1; color:var(--accent); }
.stat-label { font-size:0.8rem; color:var(--text-dim); text-transform:uppercase; letter-spacing:1px; margin-top:4px; }
.avail-dot { display:inline-flex; align-items:center; gap:0.5rem; font-size:0.8rem; color:var(--green); background:rgba(34,197,94,0.1); padding:0.35rem 0.9rem; border-radius:20px; border:1px solid rgba(34,197,94,0.2); }
.avail-dot::before { content:''; width:6px; height:6px; border-radius:50%; background:var(--green); animation:pulse 2s ease-in-out infinite; }
@keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.4} }

section { padding:6rem 2.5rem; }
.section-inner { max-width:900px; margin:0 auto; }
.section-label { font-family:'DM Mono',monospace; font-size:0.75rem; color:var(--accent); letter-spacing:2px; text-transform:uppercase; margin-bottom:0.75rem; }
.section-title { font-family:'Syne',sans-serif; font-size:clamp(1.8rem,4vw,2.8rem); font-weight:800; letter-spacing:-1px; line-height:1.1; margin-bottom:3rem; }
.section-title em { font-style:normal; color:var(--text-mid); }

#about { background:var(--surface); border-top:1px solid var(--border); border-bottom:1px solid var(--border); }
.about-grid { display:grid; grid-template-columns:1fr 1fr; gap:3rem; align-items:start; }
.about-text p { color:var(--text-mid); line-height:1.9; margin-bottom:1rem; font-size:0.95rem; }
.about-extras { display:flex; flex-direction:column; gap:1rem; }
.about-card { background:var(--card); border:1px solid var(--border); border-radius:12px; padding:1.2rem 1.4rem; }
.about-card-label { font-size:0.72rem; color:var(--text-dim); text-transform:uppercase; letter-spacing:1.5px; margin-bottom:0.5rem; font-family:'DM Mono',monospace; }
.about-card-val { font-size:0.95rem; color:var(--text); font-weight:500; }

.portfolio-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(260px,1fr)); gap:1.2rem; }
.channel-card { background:var(--card); border:1px solid var(--border); border-radius:14px; padding:1.6rem; text-decoration:none; display:block; transition:border-color 0.2s, transform 0.2s, background 0.2s; position:relative; overflow:hidden; }
.channel-card::before { content:''; position:absolute; top:0; left:0; right:0; height:2px; transition:background 0.3s, transform 0.3s; transform:scaleX(0); }
.channel-card.is-client::before  { background:var(--red); }
.channel-card.is-personal::before { background:var(--green); }
.channel-card:hover::before { transform:scaleX(1); }
.channel-card:hover { border-color:#3a3a3a; transform:translateY(-3px); background:#212121; }

.ch-badge { display:inline-block; font-size:0.7rem; font-weight:600; letter-spacing:1px; text-transform:uppercase; padding:3px 10px; border-radius:4px; margin-bottom:1rem; }
.badge-client   { background:var(--red-dim);   color:var(--red); }
.badge-personal { background:var(--green-dim); color:var(--green); }

.ch-handle { font-family:'Syne',sans-serif; font-size:1.2rem; font-weight:700; color:var(--text); margin-bottom:0.3rem; }
.ch-name   { font-size:0.9rem; color:var(--text-mid); margin-bottom:0.3rem; }
.ch-niche  { font-size:0.82rem; color:var(--text-dim); margin-bottom:1.2rem; }
.ch-link   { font-size:0.8rem; color:var(--accent); font-family:'DM Mono',monospace; }
.ch-link::after { content:' ↗'; }

#skills { background:var(--surface); border-top:1px solid var(--border); border-bottom:1px solid var(--border); }
.skills-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(200px,1fr)); gap:0.75rem; }
.skill-item { background:var(--card); border:1px solid var(--border); border-radius:10px; padding:0.9rem 1.2rem; font-size:0.9rem; color:var(--text-mid); display:flex; align-items:center; gap:0.6rem; transition:border-color 0.2s, color 0.2s; }
.skill-item:hover { border-color:var(--accent); color:var(--text); }
.skill-dot { width:6px; height:6px; border-radius:50%; background:var(--accent); flex-shrink:0; }

.contact-grid { display:grid; grid-template-columns:1fr 1fr; gap:1rem; }
.contact-card { background:var(--card); border:1px solid var(--border); border-radius:14px; padding:1.4rem 1.6rem; display:flex; align-items:center; gap:1rem; text-decoration:none; transition:border-color 0.2s, transform 0.2s; }
.contact-card:hover { border-color:var(--accent); transform:translateY(-2px); }
.contact-icon { width:42px; height:42px; background:var(--accent-dim); border-radius:10px; display:flex; align-items:center; justify-content:center; font-size:1.2rem; flex-shrink:0; }
.contact-label { font-size:0.75rem; color:var(--text-dim); text-transform:uppercase; letter-spacing:1px; margin-bottom:3px; }
.contact-val { font-size:0.9rem; color:var(--text); font-weight:500; }
.contact-cta { margin-top:2.5rem; background:var(--surface); border:1px solid var(--border); border-radius:16px; padding:2rem; text-align:center; }
.contact-cta p { color:var(--text-mid); margin-bottom:1.2rem; font-size:0.95rem; }

footer { padding:2rem 2.5rem; border-top:1px solid var(--border); display:flex; justify-content:space-between; align-items:center; font-size:0.8rem; color:var(--text-dim); flex-wrap:wrap; gap:0.5rem; }

.fade-in { opacity:0; transform:translateY(24px); transition:opacity 0.6s ease, transform 0.6s ease; }
.fade-in.visible { opacity:1; transform:none; }

@media(max-width:640px){
  nav { padding:1rem 1.2rem; }
  .nav-links { display:none; }
  section { padding:4rem 1.2rem; }
  #hero { padding:5rem 1.2rem 3rem; }
  .about-grid,.contact-grid { grid-template-columns:1fr; }
  .hero-stats { gap:1.5rem; }
  .portfolio-grid { grid-template-columns:1fr; }
}
</style>
</head>
<body>

<nav id="navbar">
  <a href="#hero" class="nav-logo">W<span>.</span></a>
  <ul class="nav-links">
    <li><a href="#about">About</a></li>
    <li><a href="#portfolio">Portfolio</a></li>
    <li><a href="#skills">Skills</a></li>
    <li><a href="#contact" class="nav-cta">Hire Me</a></li>
  </ul>
</nav>

<section id="hero">
  <div class="hero-inner">
    <div class="hero-eyebrow">YouTube Creator &amp; Video Editor</div>
    <h1 class="hero-name">
      John Welkin<br>
      <span class="line2">Alcazaren.</span>
    </h1>
    <div class="hero-role-wrap">
      I'm a&nbsp;<span class="hero-role-text"><span id="typed-text"></span><span class="cursor"></span></span>
    </div>
    <p class="hero-bio">I've been doing YouTube and video editing for about 3-4 years now, running my own channels, working with clients, and figuring out what actually gets people to watch till the end.</p>
    <div class="hero-actions">
      <a href="#portfolio" class="btn-primary">See My Work ↓</a>
      <a href="#contact" class="btn-outline">Get In Touch</a>
    </div>
    <div class="hero-stats">
      <div class="stat-item">
        <div class="stat-num">3-4</div>
        <div class="stat-label">Years Experience</div>
      </div>
      <div class="stat-item">
        <div class="stat-num">2</div>
        <div class="stat-label">Monetized Channels</div>
      </div>
      <div class="stat-item">
        <div class="stat-num">4+</div>
        <div class="stat-label">Clients Worked With</div>
      </div>
      <div style="display:flex;align-items:flex-end;padding-bottom:4px;">
        <span class="avail-dot">Open to work</span>
      </div>
    </div>
  </div>
</section>

<section id="about">
  <div class="section-inner">
    <div class="section-label">About</div>
    <h2 class="section-title">A little <em>about me</em></h2>
    <div class="about-grid">
      <div class="about-text fade-in">
        <p>I started YouTube just by figuring things out on my own, and honestly that's still how I learn best. Over 3-4 years I've built channels, edited for clients, and picked up a real understanding of what makes content actually work on the platform.</p>
        <p>I don't just cut footage. I think about pacing, hooks, thumbnails, and what keeps someone from clicking away. If your channel needs someone who gets the whole picture, not just the edit, that's where I come in.</p>
        <p>I'm flexible, easy to work with, and happy to share what I know about editing styles and marketing that actually move the numbers. Let's build something together.</p>
      </div>
      <div class="about-extras fade-in">
        <div class="about-card"><div class="about-card-label">Location</div><div class="about-card-val">Philippines 🇵🇭</div></div>
        <div class="about-card"><div class="about-card-label">Availability</div><div class="about-card-val" style="color:var(--green);">Open for projects</div></div>
        <div class="about-card"><div class="about-card-label">Niches I've Worked In</div><div class="about-card-val">Crime, Animation Storytelling, Social Media</div></div>
        <div class="about-card"><div class="about-card-label">Languages</div><div class="about-card-val">Filipino (Native), English (Conversational)</div></div>
      </div>
    </div>
  </div>
</section>

<section id="portfolio">
  <div class="section-inner">
    <div class="section-label">Portfolio</div>
    <h2 class="section-title">Channels I've <em>worked on</em></h2>
    <div class="portfolio-grid" id="portfolio-grid"></div>
  </div>
</section>

<section id="skills">
  <div class="section-inner">
    <div class="section-label">Skills</div>
    <h2 class="section-title">What I <em>bring to the table</em></h2>
    <div class="skills-grid" id="skills-grid"></div>
  </div>
</section>

<section id="contact">
  <div class="section-inner">
    <div class="section-label">Contact</div>
    <h2 class="section-title">Let's <em>work together</em></h2>
    <div class="contact-grid" id="contact-grid"></div>
    <div class="contact-cta fade-in">
      <p>Got a channel? I'd love to hear about it. Reach out on any platform and let's talk.</p>
      <a href="mailto:alcazarenwelkin09@gmail.com" class="btn-primary">Send Me an Email</a>
    </div>
  </div>
</section>

<footer>
  <span>© 2026 John Welkin Alcazaren</span>
  <span style="color:var(--text-dim);">YouTube Creator &amp; Video Editor</span>
</footer>

<script>
const channels = [
  { type:"client",   handle:"@GuiltSignal",    name:"Guilt Signal",    niche:"Crime & True Crime Niche",      url:"https://www.youtube.com/@GuiltSignal",    urlLabel:"youtube.com/@GuiltSignal" },
  { type:"client",   handle:"@Zenn0009",        name:"Zenn",            niche:"Storytelling Animation Niche",   url:"https://www.youtube.com/@Zenn0009",        urlLabel:"youtube.com/@Zenn0009" },
  { type:"client",   handle:"@CuriousOwl-l5p",  name:"A Curious Birb",  niche:"Curious & Educational Niche",   url:"https://www.youtube.com/@CuriousOwl-l5p",  urlLabel:"youtube.com/@CuriousOwl-l5p" },
  { type:"personal", handle:"@Eleyzar",          name:"Eleyzar",         niche:"Personal, Testing & Development", url:"https://www.youtube.com/@Eleyzar",        urlLabel:"youtube.com/@Eleyzar" },
];

const skills = [
  "Video Editing","YouTube Strategy","Audience Retention","Thumbnail Design",
  "Content Scheduling","Social Media Editing","Script Support","SEO & Tagging",
  "Marketing Insights","Niche Research",
];

const contacts = [
  { icon:"📧", label:"Email",    val:"alcazarenwelkin09@gmail.com", href:"mailto:alcazarenwelkin09@gmail.com" },
  { icon:"💬", label:"WhatsApp", val:"+63 938 235 3781",            href:"https://wa.me/639382353781" },
  { icon:"🔵", label:"Facebook", val:"View Profile",                href:"https://www.facebook.com/share/1GctHRoJnD/" },
  { icon:"🎮", label:"Discord",  val:"talentlesswelkin",            href:"#" },
];

// Render channels
document.getElementById('portfolio-grid').innerHTML = channels.map(ch => {
  const isClient = ch.type === 'client';
  return `
  <a class="channel-card ${isClient ? 'is-client' : 'is-personal'} fade-in" href="${ch.url}" target="_blank">
    <div class="ch-badge ${isClient ? 'badge-client' : 'badge-personal'}">${isClient ? 'Client' : 'Personal'}</div>
    <div class="ch-handle">${ch.handle}</div>
    <div class="ch-name">${ch.name}</div>
    <div class="ch-niche">${ch.niche}</div>
    <div class="ch-link">${ch.urlLabel}</div>
  </a>`;
}).join('');

// Render skills
document.getElementById('skills-grid').innerHTML = skills.map(s =>
  `<div class="skill-item fade-in"><span class="skill-dot"></span>${s}</div>`
).join('');

// Render contacts
document.getElementById('contact-grid').innerHTML = contacts.map(c =>
  `<a class="contact-card fade-in" href="${c.href}" target="_blank">
    <div class="contact-icon">${c.icon}</div>
    <div><div class="contact-label">${c.label}</div><div class="contact-val">${c.val}</div></div>
  </a>`
).join('');

// Typing animation
const roles = ["Video Editor.","Content Strategist.","YouTube Creator.","Channel Builder."];
let ri=0, ci=0, del=false;
function type() {
  const el = document.getElementById('typed-text');
  const cur = roles[ri];
  if (!del) {
    el.textContent = cur.slice(0, ++ci);
    if (ci === cur.length) { del=true; setTimeout(type,1600); return; }
    setTimeout(type, 80);
  } else {
    el.textContent = cur.slice(0, --ci);
    if (ci === 0) { del=false; ri=(ri+1)%roles.length; setTimeout(type,300); return; }
    setTimeout(type, 40);
  }
}
type();

// Nav scroll
window.addEventListener('scroll', () =>
  document.getElementById('navbar').classList.toggle('scrolled', window.scrollY > 40)
);

// Fade in
const obs = new IntersectionObserver(entries =>
  entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); }),
  { threshold: 0.1 }
);
document.querySelectorAll('.fade-in').forEach(el => obs.observe(el));
</script>
</body>
